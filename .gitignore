# =========================
# OS & Editor Files
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.iml

# =========================
# Backend (Spring Boot / Maven)
# =========================
# Ignore compiled output
target/
*.class

# Ignore packaged archives
*.jar
*.war
*.ear

# Ignore Maven wrapper jar (keeps repo small, keeps the script)
.mvn/wrapper/maven-wrapper.jar

# =========================
# Frontend (React / Vite / Node)
# =========================
# Ignore heavy dependency folders
node_modules/
/frontend/node_modules/

# Ignore production builds
dist/
dist-ssr/
/frontend/dist/

# Ignore npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# =========================
# Environment Variables & Secrets
# =========================
# NEVER push your API keys or database passwords!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local